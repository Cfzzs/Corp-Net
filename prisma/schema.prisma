datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String       @id // Discord ID (Chave Primária)
  name          String       // Discord Username (Nome de usuário do Discord)
  email         String?      // Discord Email
  image         String?      // Discord Avatar URL
  icName        String?      // Nome In Character / Nome no Jogo
  rank          String?      // Cargo Policial (ex: Agente Especial, Sargento, Delegado)
  role          String       @default("MEMBRO")
  status        String       @default("EM_TESTE")
  probationEnd  DateTime?    // Fim do período de teste (se aplicável)
  probationDuration Int?     @default(15) // Duração do período de teste em dias

  // Ocorrências / Observações recebidas por este membro
  recordsReceived Record[]   @relation("RecordsReceived")
  
  // Registros inseridos por este usuário (líderes / supervisores / admins)
  recordsCreated  Record[]   @relation("RecordsCreated")

  // Logs de auditoria executados por este admin/lider
  logsExecuted    AuditLog[] @relation("LogsExecuted")
  
  // Logs de auditoria sofridos por este usuário (ex: alteração na própria ficha)
  logsTargeted    AuditLog[] @relation("LogsTargeted")

  // Entradas na blacklist criadas por este administrador
  blacklistCreated Blacklist[] @relation("BlacklistCreated")

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Record {
  id          String     @id @default(uuid())
  type        String
  description String
  proofUrl    String?    // Link da Prova (Imgur, Medal, YouTube)
  date        DateTime   @default(now()) // Data do ocorrido

  // Relação com o membro que recebeu o registro
  userId      String
  user        User       @relation("RecordsReceived", fields: [userId], references: [id], onDelete: Cascade)

  // Relação com quem criou o registro (Líder / Admin)
  createdById String
  createdBy   User       @relation("RecordsCreated", fields: [createdById], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([createdById])
}

model Blacklist {
  id          String   @id @default(uuid())
  discordId   String   @unique // Discord ID do jogador banido
  icName      String   // Nome IC do jogador banido
  reason      String
  proofUrl    String?  // Link de Prova

  // Relação com o Admin que realizou a inclusão na Blacklist
  createdById String
  createdBy   User     @relation("BlacklistCreated", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // Tipo de ação: "UPDATE_PROFILE", "DELETE_PROFILE", "ADD_RECORD", "DELETE_RECORD", "ADD_BLACKLIST", "REMOVE_BLACKLIST"
  details     String   // Descrição humana da ação
  
  // Quem executou a ação (Lider/Admin)
  executorId  String
  executor    User     @relation("LogsExecuted", fields: [executorId], references: [id])
  
  // Quem sofreu a ação (Opcional, pois pode ser um log geral ou deletado)
  targetId    String?
  target      User?    @relation("LogsTargeted", fields: [targetId], references: [id])

  createdAt   DateTime @default(now())

  @@index([executorId])
  @@index([targetId])
}
